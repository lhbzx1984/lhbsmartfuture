{
  "buildCommand": "npm run build:pages",
  "outputDirectory": "dist/client",
  "framework": null,
  "installCommand": "npm ci",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@3.1.3"
    }
  }
}
